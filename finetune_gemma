an compare different training runs.","metadata":{}},{"cell_type":"code","source":"from rouge_score import rouge_scorer\n\nscorer = rouge_scorer.RougeScorer([\"rouge1\", \"rouge2\", \"rougeL\"], use_stemmer=True)\n\nresults = {\"rouge1\": [], \"rouge2\": [], \"rougeL\": []}\n\nprint(\"Evaluating on validation set …\")\nfor example in ds[\"validation\"].select(range(min(50, len(ds[\"validation\"])))):\n    # Extract the reference summary from the text field\n    text = example[\"text\"]\n    # The model output comes after <start_of_turn>model\\n\n    parts = text.split(\"<start_of_turn>model\\n\")\n    if len(parts) < 2:\n        continue\n    reference = parts[1].replace(\"<end_of_turn>\", \"\").strip()\n\n    # Generate a prediction\n    prompt_text = parts[0] + \"<start_of_turn>model\\n\"\n    inputs = tokenizer(\n        prompt_text,\n        return_tensors=\"pt\",\n        truncation=True,\n        max_length=MAX_SEQ_LEN,\n    ).to(model_merged.device)\n\n    prompt_len = inputs[\"input_ids\"].shape[1]\n    with torch.inference_mode():\n        out = model_merged.generate(\n            **inputs,\n            max_new_tokens=200,\n            temperature=0.7,\n            do_sample=True,\n            pad_token_id=tokenizer.pad_token_id,\n            eos_token_id=tokenizer.eos_token_id,\n        )\n    prediction = tokenizer.decode(out[0][prompt_len:], skip_special_tokens=True)\n\n    scores = scorer.score(reference, prediction)\n    for k in results:\n        results[k].append(scores[k].fmeasure)\n\nprint(\"\\n📊 ROUGE Scores (mean over validation sample):\")\nfor k, vals in results.items():\n    mean_val = sum(vals) / len(vals) if vals else 0.0\n    print(f\"   {k.upper():8s}: {mean_val:.4f}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-21T14:04:53.180598Z","iopub.status.idle":"2026-07-21T14:04:53.180861Z","shell.execute_reply.started":"2026-07-21T14:04:53.180737Z","shell.execute_reply":"2026-07-21T14:04:53.180754Z"}},"outputs":[],"execut